{
  "name": "sd-webui-interface",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "report:ui-consistency": "node tools/ui-consistency-report.mjs",
    "report:ui-consistency:strict": "node tools/ui-consistency-report.mjs --strict",
    "typecheck": "vue-tsc -p tsconfig.json --noEmit",
    "dev": "npm run typecheck && node tools/port-guard-dev.mjs",
    "build": "vite build",
    "preview": "vite preview --port 8282",
    "verify": "npm run report:ui-consistency:strict && npm run typecheck && npm run build"
  },
  "dependencies": {
    "@tiptap/core": "2.26.3",
    "@tiptap/pm": "2.26.3",
    "@tiptap/starter-kit": "2.26.3",
    "@tiptap/vue-3": "2.26.3",
    "pinia": "^3.0.3",
    "vue": "^3.5.22",
    "vue-router": "^4.5.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.13",
    "@vitejs/plugin-vue": "^6.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.1.11",
    "vue-tsc": "^2.2.8"
  }
}
